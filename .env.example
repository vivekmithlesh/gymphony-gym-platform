# Copy to .env (or set in Vercel project env) and fill in real values.

# Canonical public origin used to mint QR deep-links (/join/:id, /checkin/:id).
# MUST be the production domain — never a preview deploy or localhost — or a
# poster printed/shared from the wrong origin will scan to a dead URL (Vercel
# 404). The app prefers this over window.location.origin. See src/lib/app-url.ts.
VITE_APP_URL=https://your-production-domain.example

# Auth & Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dummy values for build/validation to pass
MINIO_ACCESS_KEY="dummy_key"
MINIO_SECRET_KEY="dummy_secret"
MINIO_BUCKET="dummy_bucket"
MSG91_API_KEY="your-key"
MSG91_TEMPLATE_ID="your-template"
